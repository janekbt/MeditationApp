#: data/io.github.janekbt.Meditate.metainfo.xml.in:11
msgid ""
"Meditate is a simple meditation companion for GNOME. It provides a countdown "
"and stopwatch timer, a session log, and statistics to help you build a "
"consistent practice."
msgstr ""

#: data/io.github.janekbt.Meditate.metainfo.xml.in:17
msgid "Countdown and stopwatch timer modes"
msgstr "Modalità conto alla rovescia e cronometro"

#: data/io.github.janekbt.Meditate.metainfo.xml.in:18
msgid "Label your sessions (sitting, walking, chanting, …)"
msgstr "Etichetta le tue sessioni (seduto, camminando, mantra, …)"

#: data/io.github.janekbt.Meditate.metainfo.xml.in:19
msgid "Add notes to each session"
msgstr "Aggiungi note a ogni sessione"

#: data/io.github.janekbt.Meditate.metainfo.xml.in:20
msgid "View your history and statistics"
msgstr "Consulta la cronologia e le statistiche"

#: data/io.github.janekbt.Meditate.metainfo.xml.in:21
msgid "Track your streak and stay consistent"
msgstr "Monitora la tua serie e mantieni la costanza"

#: data/io.github.janekbt.Meditate.metainfo.xml.in:28
msgid "Countdown timer with quick presets and streak display"
msgstr "Conto alla rovescia con preimpostazioni rapide e serie"

#: data/io.github.janekbt.Meditate.metainfo.xml.in:32
msgid "Weekly goal, 13-week heatmap, and insights"
msgstr "Obiettivo settimanale, heatmap di 13 settimane e analisi"

#: data/io.github.janekbt.Meditate.metainfo.xml.in:36
