# Cargo build output
/target/
/cargo-home/

# Host-specific cargo config for dev-xbuild (sysroot path, cross linker).
# A checked-in config.toml breaks aarch64 flatpak-builder under QEMU — the
# target settings would apply to the native aarch64 build too. The env-var
# alternative lives in build-aux/dev-xbuild.sh.
/.cargo/

# Meson build directories
/_build/
/builddir/
/build/

# flatpak-builder scratch + exported repo
/.flatpak-builder/
/flatpak_app/

# aarch64 cross-build output (see build-aux/dev-xbuild.sh)
/build-aarch64/

# raw on-device frame logs from perf measurement runs — BASELINE.md
# and PHASE5_RESULTS.md under the same dir summarise the findings
baseline/*.log

# Generated config
src/config.rs.gen

# Editor files
.vscode/
.idea/
*.swp
*.swo
