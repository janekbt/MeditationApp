<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.janekbt.Meditate</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Meditate</name>
  <summary>Meditation timer and session log</summary>

  <description>
    <p>
      Meditate is a simple meditation companion for GNOME. It provides a
      countdown and stopwatch timer, a session log, and statistics to help
      you build a consistent practice.
    </p>
    <ul>
      <li>Countdown and stopwatch timer modes</li>
      <li>Label your sessions (sitting, walking, chanting, …)</li>
      <li>Add notes to each session</li>
      <li>View your history and statistics</li>
      <li>Track your streak and stay consistent</li>
    </ul>
  </description>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/janekbt/MeditationApp/main/data/screenshots/screenshot-timer.png</image>
      <caption>Countdown timer with quick presets and streak display</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/janekbt/MeditationApp/main/data/screenshots/screenshot-stats.png</image>
      <caption>Weekly goal, 13-week heatmap, and insights</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/janekbt/MeditationApp/main/data/screenshots/screenshot-log.png</image>
      <caption>Session log grouped by date, with labels and notes</caption>
    </screenshot>
  </screenshots>

  <launchable type="desktop-id">io.github.janekbt.Meditate.desktop</launchable>
  <icon type="stock">io.github.janekbt.Meditate</icon>

  <categories>
    <category>Utility</category>
    <category>Clock</category>
  </categories>

  <url type="homepage">https://github.com/janekbt/MeditationApp</url>
  <url type="bugtracker">https://github.com/janekbt/MeditationApp/issues</url>

  <developer id="io.github.janekbt">
    <name>janekbt</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="light">#99c1f1</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

